# =============================================================================
# Synthetic AI Juror — Backend env template
# Copy to `.env` and fill in real values. Never commit `.env` to git.
# =============================================================================

# --- Server -------------------------------------------------------------------
PORT=3002
# Comma-separated list of allowed origins, or "*" for any.
# In production set to your Netlify URL, e.g. https://ai-jury.netlify.app
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Auth ---------------------------------------------------------------------
# Shared password protecting every mutating route (upload, scoring, approve,
# render). Leave blank in local dev to disable auth. In production this MUST
# be set — without it anyone with the URL can run up your HeyGen bill.
MODERATOR_PASSWORD=

# --- LLM providers (Phase 3 scoring engine) -----------------------------------
# Primary: Anthropic Claude Sonnet 4.6 with vision (image-heavy PDFs).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fallback: OpenAI GPT-4o for the synchronous critique-then-score path
# while we transition off of it. Also used by Whisper for video transcription.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Avatar (Phase 6 render pipeline) -----------------------------------------
# HeyGen Video API — renders the talking-head video per case.
# Native Russian TTS is good enough; ElevenLabs only if HeyGen TTS regresses.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
ELEVENLABS_API_KEY=

# --- Supabase (Phase 0 setup, used Phase 2+) ----------------------------------
# Project URL: https://<project-ref>.supabase.co
SUPABASE_URL=
# `anon` key — public, used by the browser
SUPABASE_ANON_KEY=
# `service_role` key — SERVER ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
# Storage buckets (created in Phase 0 setup)
SUPABASE_BUCKET_CASES=cases
SUPABASE_BUCKET_RENDERS=renders

# --- Reproducibility ----------------------------------------------------------
# Pinned versions of methodology + anchored rubric. Values are git SHAs or
# content hashes; runAnalysis stamps them onto every verdict for replay.
METHODOLOGY_VERSION=
ANCHORS_VERSION=
PROMPT_VERSION=

# --- Retention ----------------------------------------------------------------
# 1 month then export to organizers. Cron job uses these.
RETENTION_DAYS=30
EXPORT_BUCKET_PATH=

# --- Optional / deprecated ----------------------------------------------------
# DATABASE_URL is now derived from Supabase; keep blank.
DATABASE_URL=
